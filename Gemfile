
source "https://rubygems.org"

# Core Jekyll plugins
gem "jekyll-remote-theme"       # Remote theme support
gem "jekyll-paginate"           # Post pagination
gem "jekyll-feed"               # RSS/Atom feeds  
gem "jekyll-seo-tag"            # SEO meta tags
gem "jemoji"                    # Emoji support

# Content & Organization
gem "jekyll-archives"           # Automatic archive pages by date/tags
gem "jekyll-sitemap"            # XML sitemap generation
gem "jekyll-redirect-from"      # Handle URL redirects
gem "jekyll-reading-time"       # Calculate post reading time

# Performance & Optimization
gem "jekyll-minifier"           # Minify HTML/CSS/JS
gem "jekyll-compress-images"    # Image optimization
gem "jekyll-webp"               # WebP image conversion

# Social & Analytics
gem "jekyll-twitter-plugin"     # Embed tweets
gem "jekyll-analytics"          # Enhanced analytics

# Development & Administration
gem "jekyll-include-cache"      # Cache includes for performance
gem "jekyll-admin"              # Web-based admin interface

# Math & LaTeX support (optional - removed due to Ruby version compatibility)
# gem "jektex"                    # LaTeX math rendering (requires Ruby 2.7+)
